{
  "name": "@particle-academy/fancy-3d-babylon",
  "version": "0.1.1",
  "description": "Babylon.js adapter for @particle-academy/fancy-3d — WebGL renderer, primitives, React components (Stage, Monitor, Card3D, Screen) that mount onto a Babylon Scene.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-3d-babylon.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-3d-babylon#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-3d-babylon/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./engine": {
      "import": {
        "types": "./dist/engine.d.ts",
        "default": "./dist/engine.js"
      },
      "require": {
        "types": "./dist/engine.d.cts",
        "default": "./dist/engine.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "3d",
    "babylonjs",
    "webgl",
    "fancy-3d"
  ],
  "peerDependencies": {
    "@babylonjs/core": "^7.0.0 || ^8.0.0 || ^9.0.0",
    "@particle-academy/fancy-3d": "^0.4.0",
    "@particle-academy/react-fancy": ">=3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@particle-academy/react-fancy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babylonjs/core": "^9.0.0",
    "@particle-academy/fancy-3d": "^0.4.0",
    "@particle-academy/react-fancy": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
